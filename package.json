{
    "name": "@raflymln/huawei-lte-gateway",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "description": "Service gateway for interacting with Huawei LTE Modem web API endpoints",
    "license": "MPL-2.0",
    "author": {
        "name": "Rafly Maulana",
        "email": "rafly@tako.id"
    },
    "contributors": [
        {
            "name": "big-pickle",
            "url": "https://opencode.ai"
        }
    ],
    "scripts": {
        "dev": "bun run build && bun run start",
        "start": "bun run dist/app.js",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --ext .ts",
        "test": "bun run build && bun test",
        "format": "prettier --write .",
        "commitlint": "commitlint --edit",
        "prepare": "lefthook install"
    },
    "packageManager": "bun@1.3.11",
    "engines": {
        "bun": ">=1.0.0"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.1",
        "@elysiajs/openapi": "^1.4.14",
        "elysia": "^1.4.28",
        "eslint-plugin-no-relative-import-paths": "^1.6.1",
        "fast-xml-parser": "^5.5.10",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@commitlint/types": "^20.5.0",
        "@eslint/js": "^10.0.1",
        "@types/bun": "^1.3.11",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "lefthook": "^2.1.4",
        "prettier": "^3.8.1",
        "test": "^3.3.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0"
    }
}
